{
  "name": "Python 3 (PyQt6)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "settings": {
    "python.pythonPath": "/usr/local/bin/python"
  },
  "extensions": [
    "ms-python.python"
  ],
  "postCreateCommand": "pip install -r requirements.txt",
  "remoteUser": "vscode",
  "runArgs": [
    "--service-ports",
    "--env", "DISPLAY=:1"
  ],
  "containerUser": "vscode"
}